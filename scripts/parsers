#!/usr/bin/env bash

# =============================================================
# nvimz: Treesitter Parser & Query Manager
# =============================================================

set -euo pipefail

PARSER_DIR="${HOME}/.local/share/nvim/site/parser"
QUERY_ROOT="${HOME}/.config/nvim/after/queries"
TMP_DIR="/tmp/nvimz-parsers"
CC="${CC:-cc}"

# format: "lang_name:github_repo:source_subpath"
LANGS=(
  "c:tree-sitter/tree-sitter-c:src"
  "cpp:tree-sitter/tree-sitter-cpp:src"
  "go:tree-sitter/tree-sitter-go:src"
  "rust:tree-sitter/tree-sitter-rust:src"
  "python:tree-sitter/tree-sitter-python:src"
  "typescript:tree-sitter/tree-sitter-typescript:typescript/src"
  "tsx:tree-sitter/tree-sitter-typescript:tsx/src"
  "lua:tree-sitter-grammars/tree-sitter-lua:src"
  "vim:neovim/tree-sitter-vim:src"
  "vimdoc:neovim/tree-sitter-vimdoc:src"
  "gitcommit:gbprod/tree-sitter-gitcommit:src"
  "git_rebase:the-mikedavis/tree-sitter-git-rebase:src"
  "diff:the-mikedavis/tree-sitter-diff:src"
  "markdown:tree-sitter-grammars/tree-sitter-markdown:tree-sitter-markdown/src"
)

mkdir -p "$PARSER_DIR" "$TMP_DIR" "$QUERY_ROOT"

info() { printf "\033[1;34m[INFO]\033[0m %s\n" "$1"; }
ok() { printf "\033[1;32m[OK]\033[0m %s\n" "$1"; }

build_parser() {
  local lang=$1 repo=$2 sub=$3
  local target="$PARSER_DIR/$lang.so"
  
  info "$lang: Building parser..."
  local repo_dir="$TMP_DIR/$lang"
  rm -rf "$repo_dir"
  git clone --depth 1 "https://github.com/$repo" "$repo_dir" >/dev/null 2>&1
  cd "$repo_dir"

  local compiler="$CC"
  local files="$sub/parser.c"
  [ -f "$sub/scanner.cc" ] && compiler="c++" && files="$files $sub/scanner.cc"
  [ -f "$sub/scanner.c" ] && files="$files $sub/scanner.c"

  $compiler -O3 -fPIC -shared $files -I"./$sub" -o "$lang.so"
  mv "$lang.so" "$target"
}

setup_queries() {
  local lang=$1
  local qdir="$QUERY_ROOT/$lang"
  mkdir -p "$qdir"
  
  info "$lang: Downloading queries..."
  local url="https://raw.githubusercontent.com/neovim/neovim/master/runtime/queries/$lang/highlights.scm"
  if curl -fsSL -o "$qdir/highlights.scm" "$url"; then
    curl -fsSL -o "$qdir/injections.scm" "https://raw.githubusercontent.com/neovim/neovim/master/runtime/queries/$lang/injections.scm" 2>/dev/null || true
  fi

  if [[ "$lang" == "go" ]]; then
    cat <<'EOF' >>"$qdir/highlights.scm"
((call_expression function: (identifier) @constructor) (#lua-match? @constructor "^[nN]ew.+$"))
((call_expression function: (identifier) @constructor) (#lua-match? @constructor "^[mM]ake.+$"))
EOF
  fi
}

for entry in "${LANGS[@]}"; do
  IFS=":" read -r lang repo sub <<<"$entry"
  if [[ "${1:-}" == "--check" ]]; then
    [ -f "$PARSER_DIR/$lang.so" ] && echo "✅ $lang" || echo "❌ $lang"
    continue
  fi
  build_parser "$lang" "$repo" "$sub"
  setup_queries "$lang"
done

rm -rf "$TMP_DIR"
ok "Parsers managed."
