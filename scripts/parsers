#!/usr/bin/env bash

set -euo pipefail

# Configuration
PARSER_DIR="${HOME}/.local/share/nvim/site/parser"
QUERY_ROOT="${HOME}/.config/nvim/queries"
TMP_DIR="/tmp/nvimz-parsers"
CC="${CC:-cc}"

# Languages to install
# format: "lang_name:github_repo:source_subpath"
LANGS=(
  "c:tree-sitter/tree-sitter-c:src"
  "cpp:tree-sitter/tree-sitter-cpp:src"
  "go:tree-sitter/tree-sitter-go:src"
  "rust:tree-sitter/tree-sitter-rust:src"
  "python:tree-sitter/tree-sitter-python:src"
  "typescript:tree-sitter/tree-sitter-typescript:typescript/src"
  "tsx:tree-sitter/tree-sitter-typescript:tsx/src"
  "lua:tree-sitter-grammars/tree-sitter-lua:src"
  "vim:neovim/tree-sitter-vim:src"
  "vimdoc:neovim/tree-sitter-vimdoc:src"
  "gitcommit:gbprod/tree-sitter-gitcommit:src"
  "git_rebase:the-mikedavis/tree-sitter-git-rebase:src"
  "diff:the-mikedavis/tree-sitter-diff:src"
  "markdown:tree-sitter-grammars/tree-sitter-markdown:tree-sitter-markdown/src"
)

mkdir -p "$PARSER_DIR"
mkdir -p "$TMP_DIR"
mkdir -p "$QUERY_ROOT"

CHECK_ONLY=0
if [[ "${1:-}" == "--check" ]]; then
  CHECK_ONLY=1
fi

echo "--------------------------------------------------"
echo " nvimz: Treesitter Parser Manager"
echo "--------------------------------------------------"

for entry in "${LANGS[@]}"; do
  IFS=":" read -r lang repo subpath <<< "$entry"
  
  TARGET="$PARSER_DIR/$lang.so"
  QUERY_DIR="$QUERY_ROOT/$lang"
  
  PARSER_EXISTS=0
  if [ -f "$TARGET" ]; then
    PARSER_EXISTS=1
  fi

  QUERY_EXISTS=0
  if [ -f "$QUERY_DIR/highlights.scm" ]; then
    QUERY_EXISTS=1
  fi

  if [[ $CHECK_ONLY -eq 1 ]]; then
    STATUS=""
    if [[ $PARSER_EXISTS -eq 1 && $QUERY_EXISTS -eq 1 ]]; then
      STATUS="✅"
    elif [[ $PARSER_EXISTS -eq 1 ]]; then
      STATUS="⚠️ (Missing Queries)"
    else
      STATUS="❌"
    fi
    echo "$STATUS $lang"
    continue
  fi

  if [[ $PARSER_EXISTS -eq 1 && $QUERY_EXISTS -eq 1 ]]; then
    echo "✅ $lang: Already installed"
    continue
  fi

  if [[ $PARSER_EXISTS -eq 0 ]]; then
    echo "⏳ $lang: Installing parser..."
    REPO_DIR="$TMP_DIR/$lang"
    rm -rf "$REPO_DIR"
    git clone --depth 1 "https://github.com/$repo" "$REPO_DIR"
    
    cd "$REPO_DIR/$subpath"
    COMPILER="$CC"
    FILES="parser.c"
    if [ -f "scanner.cc" ]; then
      COMPILER="c++"
      FILES="$FILES scanner.cc"
    elif [ -f "scanner.c" ]; then
      FILES="$FILES scanner.c"
    fi
    $COMPILER -O3 -fPIC -shared $FILES -I. -o "$lang.so"
    mv "$lang.so" "$TARGET"
    echo "  🔨 Parser installed to $TARGET"
  fi

  if [[ $QUERY_EXISTS -eq 0 ]]; then
    echo "⏳ $lang: Downloading queries..."
    mkdir -p "$QUERY_DIR"
    
    # Try nvim-treesitter as primary source for queries
    QUERY_URL="https://raw.githubusercontent.com/nvim-treesitter/nvim-treesitter/master/queries/$lang/highlights.scm"
    
    # Special overrides
    if [[ "$lang" == "python" ]]; then
      QUERY_URL="https://raw.githubusercontent.com/neovim/neovim/master/runtime/queries/python/highlights.scm"
    fi

    if curl -fsSL -o "$QUERY_DIR/highlights.scm" "$QUERY_URL"; then
      echo "  ✨ Highlights installed"
      # Also try to get injections if they exist
      curl -fsSL -o "$QUERY_DIR/injections.scm" "https://raw.githubusercontent.com/nvim-treesitter/nvim-treesitter/master/queries/$lang/injections.scm" 2>/dev/null || true
    else
      echo "  ⚠️  Could not download highlights for $lang"
    fi
  fi
done

echo "--------------------------------------------------"
echo "Done! Restart Neovim to apply changes."
