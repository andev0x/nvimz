#!/usr/bin/env bash

set -euo pipefail

REPORT_FILE="MAINTENANCE_REPORT.md"

{
  echo "# nvimz Maintenance Report"
  echo "Date: $(date)"
  echo ""

  echo "## 1. Lockfile Validation"
  if [ -f nvim-pack-lock.json ] && jq . nvim-pack-lock.json > /dev/null; then
    echo "✅ Lockfile (\`nvim-pack-lock.json\`) is valid JSON."
  else
    echo "❌ Lockfile (\`nvim-pack-lock.json\`) is MISSING or INVALID."
  fi
  echo ""

  echo "## 2. Environment Health"
  echo "\`\`\`"
  nvim --headless -c "lua require('core.health').run_doctor()" -c "qa" 2>&1
  echo "\`\`\`"
  echo ""

  echo "## 3. Startup Benchmark"
  nvim --startuptime /tmp/nvim-startup.txt --headless -c "qa"
  STARTUP_TIME=$(grep "NVIM STARTED" /tmp/nvim-startup.txt | tail -n 1 | awk '{print $1}')
  echo "Total startup time: **${STARTUP_TIME}ms** (Target: <20ms)"
  echo ""

  echo "## 4. Parser Validation"
  echo "\`\`\`"
  ./scripts/parsers --check 2>&1 || echo "Parser check failed"
  echo "\`\`\`"
  echo ""
} > "$REPORT_FILE"

cat "$REPORT_FILE"
