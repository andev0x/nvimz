#!/usr/bin/env bash

# =========================================================
# Java + jdtls Setup for Neovim
# Supports:
#   - macOS
#   - Ubuntu/Debian
#   - Arch Linux
#
# Stack:
#   - OpenJDK 21
#   - jdtls
#   - nvim-jdtls
#   - vim.pack
# =========================================================

set -euo pipefail

# =========================================================
# Helpers
# =========================================================

info() {
  printf "\033[1;34m[INFO]\033[0m %s\n" "$1"
}

ok() {
  printf "\033[1;32m[OK]\033[0m %s\n" "$1"
}

warn() {
  printf "\033[1;33m[WARN]\033[0m %s\n" "$1"
}

err() {
  printf "\033[1;31m[ERROR]\033[0m %s\n" "$1"
}

# =========================================================
# Detect OS
# =========================================================

OS=""
PKG_MANAGER=""

if [[ "$OSTYPE" == "darwin"* ]]; then
  OS="macos"
  PKG_MANAGER="brew"

elif [[ -f /etc/arch-release ]]; then
  OS="arch"
  PKG_MANAGER="pacman"

elif [[ -f /etc/debian_version ]]; then
  OS="ubuntu"
  PKG_MANAGER="apt"

else
  err "Unsupported OS"
  exit 1
fi

info "Detected OS: $OS"

# =========================================================
# Paths
# =========================================================

HOME_DIR="$HOME"

JDTLS_DIR="$HOME_DIR/.local/share/jdtls"
BIN_DIR="$HOME_DIR/.local/bin"

PACK_DIR="$HOME_DIR/.local/share/nvim/site/pack/core/opt"
PLUGIN_DIR="$PACK_DIR/nvim-jdtls"

FTPLUGIN_DIR="$HOME_DIR/.config/nvim/ftplugin"

mkdir -p "$BIN_DIR"
mkdir -p "$PACK_DIR"
mkdir -p "$FTPLUGIN_DIR"

# =========================================================
# Install Java 21
# =========================================================

install_java() {
  info "Installing OpenJDK 21..."

  case "$OS" in
  macos)
    if ! command -v brew >/dev/null 2>&1; then
      err "Homebrew is required."
      exit 1
    fi

    brew install openjdk@21 || true

    JAVA_HOME_PATH="/opt/homebrew/opt/openjdk@21"
    JAVA_BIN="$JAVA_HOME_PATH/bin"

    ;;

  ubuntu)
    sudo apt update

    sudo apt install -y \
      openjdk-21-jdk \
      curl \
      unzip \
      tar \
      git

    JAVA_HOME_PATH="/usr/lib/jvm/java-21-openjdk-amd64"
    JAVA_BIN="$JAVA_HOME_PATH/bin"

    ;;

  arch)
    sudo pacman -Sy --noconfirm \
      jdk21-openjdk \
      curl \
      unzip \
      tar \
      git

    JAVA_HOME_PATH="/usr/lib/jvm/java-21-openjdk"
    JAVA_BIN="$JAVA_HOME_PATH/bin"

    ;;
  esac

  SHELL_RC="$HOME/.zshrc"

  if [[ -n "${BASH_VERSION:-}" ]]; then
    SHELL_RC="$HOME/.bashrc"
  fi

  if ! grep -q "JAVA_HOME" "$SHELL_RC" 2>/dev/null; then
    {
      echo
      echo "# Java"
      echo "export JAVA_HOME=\"$JAVA_HOME_PATH\""
      echo "export PATH=\"$JAVA_BIN:\$PATH\""
    } >>"$SHELL_RC"
  fi

  export JAVA_HOME="$JAVA_HOME_PATH"
  export PATH="$JAVA_BIN:$PATH"

  ok "Java installed"
}

# =========================================================
# Install jdtls
# =========================================================

install_jdtls() {
  info "Installing jdtls..."

  mkdir -p "$JDTLS_DIR"
  cd "$JDTLS_DIR"

  curl -L \
    https://download.eclipse.org/jdtls/snapshots/jdt-language-server-latest.tar.gz \
    -o jdtls.tar.gz

  tar -xzf jdtls.tar.gz
  rm -f jdtls.tar.gz

  ok "jdtls installed"
}

# =========================================================
# Create jdtls launcher
# =========================================================

create_launcher() {
  info "Creating jdtls launcher..."

  cat >"$BIN_DIR/jdtls" <<'EOF'
#!/usr/bin/env bash

set -euo pipefail

JDTLS_HOME="$HOME/.local/share/jdtls"

LAUNCHER=$(find "$JDTLS_HOME/plugins" \
  -name 'org.eclipse.equinox.launcher_*.jar' \
  | head -n 1)

if [[ -z "$LAUNCHER" ]]; then
  echo "Launcher not found"
  exit 1
fi

case "$(uname)" in
  Darwin)
    CONFIG="$JDTLS_HOME/config_mac"
    ;;
  Linux)
    CONFIG="$JDTLS_HOME/config_linux"
    ;;
  *)
    echo "Unsupported OS"
    exit 1
    ;;
esac

exec java \
  -Declipse.application=org.eclipse.jdt.ls.core.id1 \
  -Dosgi.bundles.defaultStartLevel=4 \
  -Declipse.product=org.eclipse.jdt.ls.core.product \
  -Dlog.protocol=false \
  -Dlog.level=ERROR \
  -Xms512m \
  -Xmx2G \
  --add-modules=ALL-SYSTEM \
  --add-opens java.base/java.util=ALL-UNNAMED \
  --add-opens java.base/java.lang=ALL-UNNAMED \
  -jar "$LAUNCHER" \
  -configuration "$CONFIG" \
  "$@"
EOF

  chmod +x "$BIN_DIR/jdtls"

  ok "Launcher created"
}

# =========================================================
# PATH
# =========================================================

setup_local_bin() {
  info "Configuring ~/.local/bin..."

  SHELL_RC="$HOME/.zshrc"

  if [[ -n "${BASH_VERSION:-}" ]]; then
    SHELL_RC="$HOME/.bashrc"
  fi

  if ! grep -q ".local/bin" "$SHELL_RC" 2>/dev/null; then
    {
      echo
      echo "# Local binaries"
      echo 'export PATH="$HOME/.local/bin:$PATH"'
    } >>"$SHELL_RC"
  fi

  export PATH="$HOME/.local/bin:$PATH"

  ok "PATH configured"
}

# =========================================================
# Install nvim-jdtls
# =========================================================

install_plugin() {
  info "Installing nvim-jdtls..."

  if [[ ! -d "$PLUGIN_DIR" ]]; then
    git clone \
      https://github.com/mfussenegger/nvim-jdtls \
      "$PLUGIN_DIR"
  else
    warn "nvim-jdtls already installed"
  fi

  ok "Plugin ready"
}

# =========================================================
# Create ftplugin/java.lua
# =========================================================

create_ftplugin() {
  info "Creating ftplugin/java.lua..."

  cat >"$FTPLUGIN_DIR/java.lua" <<EOF
vim.cmd("packadd nvim-jdtls")

local ok, jdtls = pcall(require, "jdtls")
if not ok then
  return
end

local root_markers = {
  ".git",
  "mvnw",
  "gradlew",
  "pom.xml",
  "build.gradle",
}

local root_dir = require("jdtls.setup").find_root(root_markers)

if not root_dir then
  return
end

local home = os.getenv("HOME")

local project_name =
  vim.fn.fnamemodify(root_dir, ":p:h:t")

local workspace_dir =
  home .. "/.cache/jdtls/" .. project_name

jdtls.start_or_attach({
  cmd = {
    "jdtls",
    "-data",
    workspace_dir,
  },

  root_dir = root_dir,

  settings = {
    java = {
      eclipse = {
        downloadSources = true,
      },

      configuration = {
        updateBuildConfiguration = "interactive",
      },

      maven = {
        downloadSources = true,
      },

      implementationsCodeLens = {
        enabled = true,
      },

      referencesCodeLens = {
        enabled = true,
      },

      references = {
        includeDecompiledSources = true,
      },

      format = {
        enabled = true,
      },
    },
  },

  init_options = {
    bundles = {},
  },
})
EOF

  ok "ftplugin created"
}

# =========================================================
# Main
# =========================================================

install_java
install_jdtls
create_launcher
setup_local_bin
install_plugin
create_ftplugin

# =========================================================
# Final
# =========================================================

echo
echo "=================================================="
ok "Java Neovim setup complete"
echo "=================================================="

echo
echo "Restart shell:"
echo
echo "  source ~/.zshrc"
echo
echo "or"
echo
echo "  source ~/.bashrc"
echo
echo "Check:"
echo
echo "  java --version"
echo "  jdtls"
echo
echo "Open Java project:"
echo
echo "  nvim ."
echo
echo "Inside Neovim:"
echo
echo "  :LspInfo"
echo
