#!/usr/bin/env bash

# =============================================================
# nvimz: Health Doctor
# =============================================================

set -euo pipefail

TOOLS=(
  git
  rg
  fd
  gopls
  lua-language-server
  stylua
  shfmt
  rustc
  python3
  node
  java
  jdtls
)

PARSERS=(
  c
  cpp
  go
  rust
  python
  typescript
  tsx
  lua
  vim
  vimdoc
)

PARSER_DIR="${HOME}/.local/share/nvim/site/parser"

ok() { printf "\033[1;32m[OK]\033[0m %-24s\n" "$1"; }
err() { printf "\033[1;31m[MISSING]\033[0m %-24s\n" "$1"; }

echo -e "\n--- Core Tools ---"
for tool in "${TOOLS[@]}"; do
  if command -v "$tool" >/dev/null 2>&1; then
    ok "$tool"
  else
    err "$tool"
  fi
done

echo -e "\n--- Treesitter Parsers ---"
for parser in "${PARSERS[@]}"; do
  if [ -f "$PARSER_DIR/$parser.so" ]; then
    ok "$parser"
  else
    err "$parser"
  fi
done

echo ""
