#!/usr/bin/env bash

# =============================================================
# nvimz: Universal Development Environment Setup
#
# Supported:
#   - macOS
#   - Ubuntu / Debian
#   - Arch Linux
#
# Features:
#   - Smart OS detection
#   - Language toolchain setup (Go, Rust, Python, C++, Java, Node)
#   - Local machine configuration
#   - Shell environment updates
#   - Toolchain validation
# =============================================================

set -euo pipefail

# =============================================================
# UI Helpers
# =============================================================

info() { printf "\033[1;34m[INFO]\033[0m %s\n" "$1"; }
ok() { printf "\033[1;32m[OK]\033[0m %s\n" "$1"; }
warn() { printf "\033[1;33m[WARN]\033[0m %s\n" "$1"; }
err() { printf "\033[1;31m[ERROR]\033[0m %s\n" "$1"; }
has() { command -v "$1" >/dev/null 2>&1; }

# =============================================================
# Detect OS
# =============================================================

OS=""
if [[ "$OSTYPE" == "darwin"* ]]; then
  OS="macos"
elif [[ -f /etc/arch-release ]]; then
  OS="arch"
elif [[ -f /etc/debian_version ]]; then
  OS="ubuntu"
else
  err "Unsupported OS"
  exit 1
fi
ok "Detected OS: $OS"

# =============================================================
# Environment Paths
# =============================================================

LOCAL_BIN="$HOME/.local/bin"
LOCAL_SHARE="$HOME/.local/share"
mkdir -p "$LOCAL_BIN" "$LOCAL_SHARE"
export PATH="$LOCAL_BIN:$PATH"

# =============================================================
# Package Manager Wrapper
# =============================================================

install_pkg() {
  case "$OS" in
    macos) brew install "$@" ;;
    ubuntu) sudo apt update && sudo apt install -y "$@" ;;
    arch) 
      if has yay; then yay -S --needed --noconfirm "$@"
      elif has paru; then paru -S --needed --noconfirm "$@"
      else sudo pacman -S --needed --noconfirm "$@"
      fi
      ;;
  esac
}

# =============================================================
# Core Tools
# =============================================================

setup_core() {
  info "Installing core dependencies"
  case "$OS" in
    macos) install_pkg git curl wget unzip tar ripgrep fd fzf lua-language-server stylua shfmt ;;
    ubuntu) 
      install_pkg git curl wget unzip tar ripgrep fd-find fzf build-essential
      [ ! -f "$LOCAL_BIN/fd" ] && has fdfind && ln -sf "$(command -v fdfind)" "$LOCAL_BIN/fd"
      ;;
    arch) install_pkg git curl wget unzip tar ripgrep fd fzf base-devel lua-language-server stylua shfmt ;;
  esac
}

# =============================================================
# Language Toolchains
# =============================================================

setup_go() {
  info "Setting up Go environment"
  has go || install_pkg go
  export GOPATH="$HOME/go"
  export PATH="$GOPATH/bin:$PATH"
  has gopls || go install golang.org/x/tools/gopls@latest
  has goimports || go install golang.org/x/tools/cmd/goimports@latest
}

setup_rust() {
  info "Setting up Rust environment"
  if ! has rustc; then
    curl https://sh.rustup.rs -sSf | sh -s -- -y
  fi
  source "$HOME/.cargo/env" 2>/dev/null || export PATH="$HOME/.cargo/bin:$PATH"
  rustup component add rust-analyzer rustfmt clippy || true
}

setup_python() {
  info "Setting up Python environment"
  case "$OS" in
    macos) install_pkg python pipx ;;
    ubuntu) install_pkg python3 python3-pip python3-venv pipx ;;
    arch) install_pkg python python-pip python-pipx ;;
  esac
  has basedpyright || pipx install basedpyright
  has ruff || pipx install ruff
}

setup_node() {
  info "Setting up Node.js environment"
  has node || install_pkg nodejs npm
  has typescript-language-server || npm install -g typescript typescript-language-server vscode-langservers-extracted prettier
}

setup_java() {
  info "Setting up Java environment"
  case "$OS" in
    macos) install_pkg openjdk@21 && export JAVA_HOME="/opt/homebrew/opt/openjdk@21" ;;
    ubuntu) install_pkg openjdk-21-jdk && export JAVA_HOME="/usr/lib/jvm/java-21-openjdk-amd64" ;;
    arch) install_pkg jdk21-openjdk && export JAVA_HOME="/usr/lib/jvm/java-21-openjdk" ;;
  esac
  export PATH="$JAVA_HOME/bin:$PATH"
  
  if ! has jdtls; then
    JDTLS_DIR="$LOCAL_SHARE/jdtls"
    mkdir -p "$JDTLS_DIR" && cd "$JDTLS_DIR"
    curl -L https://download.eclipse.org/jdtls/milestones/1.51.0/jdt-language-server-1.51.0-202505291357.tar.gz -o jdtls.tar.gz
    tar -xzf jdtls.tar.gz && rm jdtls.tar.gz
    
    cat >"$LOCAL_BIN/jdtls" <<EOF
#!/usr/bin/env bash
JDTLS_HOME="\$HOME/.local/share/jdtls"
LAUNCHER=\$(find "\$JDTLS_HOME/plugins" -name 'org.eclipse.equinox.launcher_*.jar' | head -n 1)
case "\$(uname)" in
  Darwin) CONFIG="\$JDTLS_HOME/config_mac" ;;
  *) CONFIG="\$JDTLS_HOME/config_linux" ;;
esac
exec java -Declipse.application=org.eclipse.jdt.ls.core.id1 -Dosgi.bundles.defaultStartLevel=4 \
  -Declipse.product=org.eclipse.jdt.ls.core.product -Dlog.level=ERROR -Xms512m -Xmx2G \
  --add-modules=ALL-SYSTEM --add-opens java.base/java.util=ALL-UNNAMED --add-opens java.base/java.lang=ALL-UNNAMED \
  -jar "\$LAUNCHER" -configuration "\$CONFIG" "\$@"
EOF
    chmod +x "$LOCAL_BIN/jdtls"
  fi
}

# =============================================================
# Machine Config
# =============================================================

setup_machine() {
  info "Configuring machine-specific settings"
  LOCAL_CONFIG="lua/machine/local.lua"
  EXAMPLE_CONFIG="lua/machine/example.lua"
  if [ ! -f "$LOCAL_CONFIG" ] && [ -f "$EXAMPLE_CONFIG" ]; then
    cp "$EXAMPLE_CONFIG" "$LOCAL_CONFIG"
    ok "Created $LOCAL_CONFIG from example"
  fi
}

# =============================================================
# Shell Configuration
# =============================================================

setup_shell() {
  info "Updating shell configuration"
  SHELL_RC="$HOME/.zshrc"
  [ -z "${BASH_VERSION:-}" ] || SHELL_RC="$HOME/.bashrc"
  
  PATHS=(
    'export PATH="$HOME/.local/bin:$PATH"'
    'export GOPATH="$HOME/go"'
    'export PATH="$GOPATH/bin:$PATH"'
    'export PATH="$HOME/.cargo/bin:$PATH"'
  )
  
  for p in "${PATHS[@]}"; do
    grep -q "$p" "$SHELL_RC" 2>/dev/null || echo "$p" >> "$SHELL_RC"
  done
}

# =============================================================
# Main Execution
# =============================================================

setup_core
setup_go
setup_rust
setup_python
setup_node
setup_java
setup_machine
setup_shell

# Final Treesitter check
if [ -f "./scripts/parsers" ]; then
  info "Installing Treesitter parsers"
  ./scripts/parsers
fi

ok "Setup complete! Please restart your shell."
