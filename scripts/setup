#!/usr/bin/env bash

# ============================================================
# nvimz: Universal Development Environment Setup
# ============================================================

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ------------------------------------------------------------
# Libraries
# ------------------------------------------------------------

source "$ROOT_DIR/lib/common.sh"
source "$ROOT_DIR/lib/platform.sh"
source "$ROOT_DIR/lib/packages.sh"
source "$ROOT_DIR/lib/logging.sh"
source "$ROOT_DIR/lib/prompts.sh"

# ------------------------------------------------------------
# Defaults
# ------------------------------------------------------------

MODE=""
LANGS=()

# ------------------------------------------------------------
# Help
# ------------------------------------------------------------

show_help() {
  cat <<EOF
nvimz setup

Usage:
  ./scripts/setup [OPTIONS]

Options:
  --minimal           Interactive minimal installation
  --full              Install full default environment
  --langs=<list>      Install only selected languages
  --help              Show this help message

Examples:
  ./scripts/setup --minimal
  ./scripts/setup --full
  ./scripts/setup --langs=go,lua,rust
EOF
}

# ------------------------------------------------------------
# Argument Parsing
# ------------------------------------------------------------

for arg in "$@"; do
  case "$arg" in
  --minimal)
    MODE="minimal"
    ;;
  --full)
    MODE="full"
    ;;
  --langs=*)
    MODE="custom"
    IFS=',' read -ra LANGS <<<"${arg#*=}"
    ;;
  --help | -h)
    show_help
    exit 0
    ;;
  *)
    error "Unknown option: $arg"
    echo
    show_help
    exit 1
    ;;
  esac
done

# ------------------------------------------------------------
# Validate Mode
# ------------------------------------------------------------

if [[ -z "$MODE" ]]; then
  show_help
  exit 1
fi

# ------------------------------------------------------------
# Platform Detection
# ------------------------------------------------------------

detect_os
info "Detected OS: $OS"

# ------------------------------------------------------------
# Language Provisioning
# ------------------------------------------------------------

provision_language() {
  local lang="$1"
  local script="$ROOT_DIR/lang/${lang}.sh"

  if [[ -f "$script" ]]; then
    info "Provisioning language: $lang"

    source "$script"

    if declare -f "install_${lang}_deps" >/dev/null; then
      "install_${lang}_deps"
    else
      warn "Missing install_${lang}_deps function"
    fi
  else
    warn "No provisioning script found for: $lang"
  fi
}

# ------------------------------------------------------------
# Minimal Mode
# ------------------------------------------------------------

run_minimal_mode() {
  info "Minimal setup mode"

  local available=(
    go
    lua
    python
    rust
    java
    terraform
    markdown
    typescript
  )

  echo
  echo "Select languages to install:"
  echo

  for lang in "${available[@]}"; do
    read -rp "Install ${lang}? [y/N]: " answer

    case "$answer" in
    y | Y)
      provision_language "$lang"
      ;;
    esac
  done
}

# ------------------------------------------------------------
# Full Mode
# ------------------------------------------------------------

run_full_mode() {
  info "Full setup mode"

  local defaults=(
    go
    rust
    python
    node
    java
  )

  for lang in "${defaults[@]}"; do
    provision_language "$lang"
  done
}

# ------------------------------------------------------------
# Custom Mode
# ------------------------------------------------------------

run_custom_mode() {
  info "Custom language setup"

  for lang in "${LANGS[@]}"; do
    provision_language "$lang"
  done
}

# ------------------------------------------------------------
# Execute
# ------------------------------------------------------------

case "$MODE" in
minimal)
  run_minimal_mode
  ;;
full)
  run_full_mode
  ;;
custom)
  run_custom_mode
  ;;
esac

# ------------------------------------------------------------
# Done
# ------------------------------------------------------------

ok "Setup complete!"
