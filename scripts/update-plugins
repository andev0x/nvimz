#!/usr/bin/env bash

set -euo pipefail

PLUGIN_DIR="$HOME/.local/share/nvim/site/pack/core/opt"

echo "ó°š° Updating Neovim plugins..."
echo

updated=0

for dir in "$PLUGIN_DIR"/*; do
  [ -d "$dir/.git" ] || continue

  name=$(basename "$dir")

  echo "ó°†“ $name"

  git -C "$dir" fetch origin --quiet

  BRANCH=$(git -C "$dir" remote show origin | sed -n '/HEAD branch/s/.*: //p')

  LOCAL=$(git -C "$dir" rev-parse HEAD)
  REMOTE=$(git -C "$dir" rev-parse "origin/$BRANCH")

  if [ "$LOCAL" != "$REMOTE" ]; then
    echo "  â†’ updating to origin/$BRANCH"

    git -C "$dir" checkout "$BRANCH" >/dev/null 2>&1 || true
    git -C "$dir" pull --ff-only origin "$BRANCH"

    updated=$((updated + 1))
  else
    echo "  â†’ already up to date"
  fi

  echo
done

echo "ó°„¬ Updated plugins: $updated"

echo
echo "ó°š° Updating Treesitter parsers..."
./scripts/parsers

echo
echo "ó°„¬ Done."
