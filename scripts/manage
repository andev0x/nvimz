#!/usr/bin/env bash

# =============================================================
# nvimz: Maintenance and Management
#
# Tasks:
#   - Update plugins
#   - Sync system dependencies
#   - Generate maintenance report
#   - Validate toolchain
# =============================================================

set -euo pipefail

# =============================================================
# UI Helpers
# =============================================================

info() { printf "\033[1;34m[INFO]\033[0m %s\n" "$1"; }
ok() { printf "\033[1;32m[OK]\033[0m %s\n" "$1"; }
warn() { printf "\033[1;33m[WARN]\033[0m %s\n" "$1"; }
err() { printf "\033[1;31m[ERROR]\033[0m %s\n" "$1"; }

# =============================================================
# Tasks
# =============================================================

update_plugins() {
  info "Updating Neovim plugins..."
  nvim --headless -c "lua require('infra.deps').update()" -c "qa"
  ok "Plugins updated."
}

sync_system() {
  info "Syncing system packages..."
  if command -v brew >/dev/null 2>&1; then
    brew upgrade
  elif [[ -f /etc/arch-release ]]; then
    if command -v yay >/dev/null 2>&1; then yay -Syu
    elif command -v paru >/dev/null 2>&1; then paru -Syu
    else sudo pacman -Syu
    fi
  elif [[ -f /etc/debian_version ]]; then
    sudo apt update && sudo apt upgrade -y
  fi
  ok "System packages synced."
}

generate_report() {
  info "Generating maintenance report..."
  REPORT_FILE="MAINTENANCE_REPORT.md"
  {
    echo "# nvimz Maintenance Report"
    echo "Date: $(date)"
    echo ""
    echo "## 1. Environment Health"
    echo "\`\`\`"
    nvim --headless -c "lua require('infra.health').run_doctor()" -c "qa" 2>&1
    echo "\`\`\`"
    echo ""
    echo "## 2. Startup Benchmark"
    nvim --startuptime /tmp/nvim-startup.txt --headless -c "qa"
    STARTUP_TIME=$(grep "NVIM STARTED" /tmp/nvim-startup.txt | tail -n 1 | awk '{print $1}')
    echo "Total startup time: **${STARTUP_TIME}ms**"
    echo ""
  } > "$REPORT_FILE"
  ok "Report generated: $REPORT_FILE"
}

# =============================================================
# Main
# =============================================================

usage() {
  echo "Usage: $0 [task]"
  echo ""
  echo "Tasks:"
  echo "  --update    Update plugins"
  echo "  --sync      Sync system packages"
  echo "  --report    Generate maintenance report"
  echo "  --all       Run all tasks"
  exit 1
}

if [[ $# -eq 0 ]]; then
  usage
fi

case "$1" in
  --update) update_plugins ;;
  --sync) sync_system ;;
  --report) generate_report ;;
  --all)
    update_plugins
    sync_system
    generate_report
    ;;
  *) usage ;;
esac
